{
  "type": "Microsoft.ContainerInstance/containerGroups",
  "apiVersion": "2023-05-01",
  "name": "aegis-passport-tee",
  "location": "eastus",
  "properties": {
    "sku": "Confidential",
    "confidentialComputeProperties": {
      "ccePolicy": "VENCX0lNQUdFPQpNT0NLX0lNQUdFX0hBU0hfVENCX0ZTPWQxMWU0MzNlZmZkNDM0ZmJlN2ZiOTEwNDI0ZTBlNWY2OWZiZmI1YzVlMjU4OWFiOWY2NGQwZDllYzUzY2FmOTgK"
    },
    "containers": [
      {
        "name": "aegis-passport-runtime",
        "properties": {
          "image": "aegis_passport_local:latest",
          "ports": [
            {
              "protocol": "TCP",
              "port": 8080
            }
          ],
          "resources": {
            "requests": {
              "memoryInGB": 2,
              "cpu": 1
            }
          ],
          "environmentVariables": [
            {
              "name": "NODE_ENV",
              "value": "production"
            },
            {
              "name": "R2_ACCOUNT_ID",
              "secureValue": "${R2_ACCOUNT_ID}"
            },
            {
              "name": "R2_ACCESS_KEY_ID",
              "secureValue": "${R2_ACCESS_KEY_ID}"
            },
            {
              "name": "R2_SECRET_ACCESS_KEY",
              "secureValue": "${R2_SECRET_ACCESS_KEY}"
            },
            {
              "name": "R2_BUCKET_NAME",
              "value": "${R2_BUCKET_NAME}"
            }
          ]
        }
      }
    ],
    "osType": "Linux",
    "restartPolicy": "Always",
    "ipAddress": {
      "type": "Public",
      "ports": [
        {
          "protocol": "TCP",
          "port": 8080
        }
      ]
    }
  }
}
